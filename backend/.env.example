# Copy this file to .env and fill in your values

PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio_db

# JWT secret — gunakan string acak yang panjang
JWT_SECRET=ganti-dengan-secret-panjang-dan-acak-minimal-32-karakter

# Admin credentials (hanya untuk seed awal — bisa diganti via DB setelah itu)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Origin yang diizinkan (frontend dev server)
CORS_ORIGIN=http://localhost:5173
